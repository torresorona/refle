# ---------------------------------------------------------------------------
# refle environment configuration. Copy to `.env` and adjust for local dev.
# ---------------------------------------------------------------------------

# --- Core / API ---
REFLE_ENV=development
# Edition: core (Hosted Core / OSS) or enterprise. Drives "Coming Soon" UI gating.
REFLE_EDITION=core
# Must be >= 32 bytes. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
REFLE_SECRET_KEY=dev-only-insecure-secret-change-me-in-production
# Async SQLAlchemy URL (asyncpg). Matches deploy/docker-compose.yml defaults.
REFLE_DATABASE_URL=postgresql+asyncpg://refle:refle@localhost:5432/refle
REFLE_REDIS_URL=redis://localhost:6379/0
REFLE_CORS_ORIGINS=http://localhost:3000

# --- Object storage (MinIO / S3-compatible) ---
REFLE_S3_ENDPOINT_URL=http://localhost:9000
REFLE_S3_ACCESS_KEY=refle
REFLE_S3_SECRET_KEY=refle-secret
REFLE_S3_BUCKET=refle-evidence

# --- AI gateway (provider-agnostic) ---
# provider: gemini | openai | local
REFLE_AI_PROVIDER=gemini
REFLE_AI_MODEL=gemini-3.5-flash
# Agent tier (policy drafting, posture summaries). Set this to a stronger Pro SKU
# for higher-quality drafts; defaults to the chat model above if unset.
REFLE_AI_AGENT_MODEL=gemini-3.5-flash
# embedding_provider: hash (offline, default; no key needed) | gemini
# After switching to gemini, run POST /ai/reindex so all vectors use the same model.
REFLE_AI_EMBEDDING_PROVIDER=hash
REFLE_AI_EMBEDDING_MODEL=gemini-embedding-001
# Cloud provider keys (only the selected provider's key is required).
GEMINI_API_KEY=
OPENAI_API_KEY=
# Sovereign / local mode: point at any OpenAI-compatible endpoint (Ollama, vLLM).
REFLE_AI_LOCAL_BASE_URL=http://localhost:11434/v1
REFLE_AI_LOCAL_MODEL=llama3.1

# --- Email Notifications ---
# To send notifications via a generic SMTP relay (e.g., Google Workspace, Office365, Postfix):
REFLE_SMTP_HOST=
REFLE_SMTP_PORT=587
REFLE_SMTP_USER=
REFLE_SMTP_PASSWORD=
REFLE_SMTP_TLS=true
REFLE_SMTP_FROM=notifications@refle.ai

# Alternatively, to send via Resend's API (without SMTP):
RESEND_API_KEY=

# --- Enterprise (optional; community core runs fine without it) ---
# A license key unlocks features registered by the private refle-enterprise repo.
REFLE_LICENSE_KEY=

# --- Web (apps/web) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
